<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OB-GYN OR Schedule · KSH</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0f0a1a;--surface:#1a1228;--surface2:#211535;--border:#2d2040;--border2:#3d2d55;
  --text:#f0e8ff;--muted:#7d6a90;--muted2:#9d8ab0;
  --p1:#c084fc;--p1bg:rgba(192,132,252,.15);
  --p2:#fb923c;--p2bg:rgba(251,146,60,.15);
  --p3:#34d399;--p3bg:rgba(52,211,153,.15);
  --warn:#fb923c;--warnbg:rgba(251,146,60,.12);
  --px:2.6px;
}
body{background:var(--bg);color:var(--text);font-family:'IBM Plex Sans Thai',system-ui,sans-serif;min-height:100vh;padding:18px;}
button,select{font-family:inherit;}

/* HEADER */
.header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px;border-bottom:1px solid var(--border);padding-bottom:14px;flex-wrap:wrap;gap:10px;}
.dept-tag{font-size:.68rem;font-weight:700;color:var(--p1);text-transform:uppercase;letter-spacing:.1em;margin-bottom:3px;}
h1{font-size:1.25rem;font-weight:800;letter-spacing:-.02em;}
.sync-msg{font-size:.72rem;font-family:'IBM Plex Mono',monospace;transition:opacity .3s;}
.doc-pills{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px;}
.doc-pill{font-size:.72rem;font-weight:600;padding:3px 10px;border-radius:20px;border:1px solid;}

/* CONTROLS */
.controls{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;align-items:flex-end;}
.ctrl-group{display:flex;flex-direction:column;gap:5px;}
.ctrl-label{font-size:.67rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;}
select.sel{background:var(--surface);border:1px solid var(--border2);color:var(--text);padding:7px 12px;border-radius:8px;font-size:.85rem;outline:none;cursor:pointer;min-width:170px;}
.day-btns{display:flex;gap:6px;flex-wrap:wrap;}
.day-btn{padding:7px 14px;border:1px solid var(--border);border-radius:8px;background:var(--surface);color:var(--muted);cursor:pointer;font-size:.82rem;font-weight:600;line-height:1.4;text-align:center;transition:all .15s;}
.day-btn.active{border-color:var(--p1);background:var(--p1bg);color:var(--p1);}
.day-btn span{display:block;font-size:.58rem;opacity:.75;font-family:'IBM Plex Mono',monospace;}
.btn-ghost{padding:7px 14px;border:1px solid var(--border2);border-radius:8px;background:transparent;color:var(--muted2);cursor:pointer;font-size:.85rem;white-space:nowrap;transition:opacity .15s;}
.btn-ghost:hover{opacity:.75;}

/* CONFLICT BANNER */
.conflict-banner{background:var(--warnbg);border:1px solid var(--warn);border-radius:8px;padding:8px 14px;font-size:.8rem;color:var(--warn);margin-bottom:14px;display:none;}
.conflict-banner.show{display:block;}

/* TIMELINE */
.timeline-wrapper{overflow-x:auto;margin-bottom:4px;}
.time-axis{position:relative;height:22px;margin-left:120px;margin-bottom:6px;}
.time-tick{position:absolute;transform:translateX(-50%);font-family:'IBM Plex Mono',monospace;white-space:nowrap;}
.time-tick.major{font-size:.65rem;color:var(--muted);}
.time-tick.minor{font-size:.58rem;color:#4a3d60;}
.room-row{display:flex;align-items:stretch;margin-bottom:10px;}
.room-label{width:115px;flex-shrink:0;display:flex;flex-direction:column;justify-content:center;padding-right:10px;}
.room-label .name{font-size:.9rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.room-label .hrs{font-size:.65rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;}
.track{position:relative;min-height:76px;background:var(--surface);border:1px solid var(--border);border-radius:8px;cursor:crosshair;flex-shrink:0;overflow:visible;}
.gridline{position:absolute;top:0;bottom:0;width:1px;pointer-events:none;}
.op-block{position:absolute;top:5px;bottom:5px;border-left:4px solid;border-radius:6px;padding:5px 12px;display:flex;flex-direction:column;justify-content:center;cursor:pointer;overflow:hidden;z-index:2;user-select:none;gap:2px;transition:filter .1s;}
.op-block:hover{filter:brightness(1.3);}
.op-block .op-name{font-size:.88rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.op-block .op-time{font-size:.68rem;color:var(--muted2);font-family:'IBM Plex Mono',monospace;white-space:nowrap;}
.resize-handle{position:absolute;right:0;top:0;bottom:0;width:10px;cursor:ew-resize;border-radius:0 6px 6px 0;z-index:5;}
.resize-handle:hover{background:rgba(255,255,255,.15);}

/* SUMMARY TABLE */
.summary-title{font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin:18px 0 8px;}
.summary-table{background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.summary-row{display:grid;grid-template-columns:88px 110px 1fr 65px;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s;}
.summary-row:last-child{border-bottom:none;}
.summary-row:hover{background:var(--surface2);}
.s-time{font-family:'IBM Plex Mono',monospace;font-size:.75rem;color:var(--muted2);display:flex;align-items:center;}
.s-doc{font-size:.83rem;font-weight:700;display:flex;align-items:center;}
.s-op{font-size:.85rem;color:var(--text);display:flex;align-items:center;}
.s-dur{font-family:'IBM Plex Mono',monospace;font-size:.7rem;color:var(--muted);display:flex;align-items:center;justify-content:flex-end;}

/* WORKLOAD */
.workload{display:flex;gap:12px;flex-wrap:wrap;margin-top:14px;}
.wl-card{flex:1;min-width:130px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 14px;}
.wl-name{font-size:.75rem;font-weight:700;margin-bottom:6px;}
.wl-bar-bg{height:5px;background:var(--border2);border-radius:3px;overflow:hidden;margin-bottom:5px;}
.wl-bar-fill{height:100%;border-radius:3px;transition:width .3s;}
.wl-text{font-family:'IBM Plex Mono',monospace;font-size:.68rem;color:var(--muted);}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:100;backdrop-filter:blur(4px);}
.overlay.hidden{display:none;}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:14px;padding:24px;width:400px;max-width:95vw;}
.modal-title{font-size:.95rem;font-weight:700;margin-bottom:16px;}
.modal-subtitle{font-size:.7rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;margin-left:8px;}
.form-row{margin-bottom:14px;}
.form-label{font-size:.67rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;display:block;}
.doc-btns{display:flex;gap:8px;}
.doc-btn{flex:1;padding:9px 4px;border:2px solid var(--border);border-radius:8px;background:var(--surface2);color:var(--muted);cursor:pointer;font-size:.78rem;font-weight:700;transition:all .15s;text-align:center;}
.fsel{width:100%;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:8px 12px;border-radius:8px;font-family:inherit;font-size:.85rem;outline:none;}
.time-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.time-sublabel{font-size:.65rem;color:var(--muted);margin-bottom:3px;}
.dur-hint{font-size:.72rem;margin-top:5px;font-family:'IBM Plex Mono',monospace;}
.conflict-msg{background:var(--warnbg);border:1px solid var(--warn);border-radius:6px;padding:7px 12px;font-size:.75rem;color:var(--warn);margin-bottom:12px;display:none;}
.conflict-msg.show{display:block;}
.modal-actions{display:flex;gap:8px;margin-top:18px;justify-content:flex-end;}
.btn-primary{padding:8px 18px;border:none;border-radius:8px;background:var(--p1);color:#0f0a1a;font-weight:700;cursor:pointer;font-size:.85rem;}
.btn-cancel{padding:8px 14px;border:1px solid var(--border2);border-radius:8px;background:transparent;color:var(--muted2);cursor:pointer;font-size:.85rem;}
.btn-delete{padding:8px 14px;border:none;border-radius:8px;background:var(--warnbg);color:var(--warn);cursor:pointer;font-size:.85rem;margin-right:auto;}
</style>
</head>
<body>

<div class="header">
  <div>
    <div class="dept-tag">สูตินรีเวช · OB-GYN</div>
    <h1>OR Elective Schedule</h1>
  </div>
  <div>
    <div id="syncMsg" class="sync-msg" style="color:#34d399;min-height:18px;text-align:right;"></div>
    <div class="doc-pills" id="docPills"></div>
  </div>
</div>

<div class="controls">
  <div class="ctrl-group">
    <div class="ctrl-label">สัปดาห์</div>
    <select class="sel" id="weekSel" onchange="renderAll()">
      <option value="0">สัปดาห์ที่ 1 (2–6 มิ.ย.)</option>
      <option value="1">สัปดาห์ที่ 2 (9–13 มิ.ย.)</option>
      <option value="2">สัปดาห์ที่ 3 (16–20 มิ.ย.)</option>
      <option value="3">สัปดาห์ที่ 4 (23–27 มิ.ย.)</option>
    </select>
  </div>
  <div class="ctrl-group">
    <div class="ctrl-label">วัน</div>
    <div class="day-btns" id="dayBtns"></div>
  </div>
  <button class="btn-ghost" onclick="clearDay()">🗑 ล้างวันนี้</button>
  <button class="btn-ghost" onclick="exportDay()">📋 Export</button>
</div>

<div class="conflict-banner" id="conflictBanner">⚠️ <strong>มีความขัดแย้ง!</strong> แพทย์บางท่านถูก assign ซ้อนทับกัน</div>

<div class="timeline-wrapper">
  <div id="timelineInner">
    <div class="time-axis" id="timeAxis"></div>
    <div id="trackArea"></div>
  </div>
</div>

<div id="summarySection"></div>
<div class="workload" id="workload"></div>

<!-- Modal -->
<div class="overlay hidden" id="overlay">
  <div class="modal">
    <div class="modal-title" id="modalTitle">
      ➕ เพิ่ม Operation<span class="modal-subtitle" id="modalSub"></span>
    </div>
    <div class="conflict-msg" id="modalConflict"></div>
    <div class="form-row">
      <label class="form-label">แพทย์</label>
      <div class="doc-btns" id="docBtns"></div>
    </div>
    <div class="form-row">
      <label class="form-label">Operation</label>
      <select class="fsel" id="fOp"></select>
    </div>
    <div class="form-row">
      <label class="form-label">ช่วงเวลา</label>
      <div class="time-grid">
        <div>
          <div class="time-sublabel">เริ่ม</div>
          <select class="fsel" id="fStart" onchange="onTimeChange()"></select>
        </div>
        <div>
          <div class="time-sublabel">สิ้นสุด</div>
          <select class="fsel" id="fEnd" onchange="onTimeChange()"></select>
        </div>
      </div>
      <div class="dur-hint" id="durHint"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-delete" id="btnDelete" style="display:none" onclick="deleteOp()">ลบ</button>
      <button class="btn-cancel" onclick="closeModal()">ยกเลิก</button>
      <button class="btn-primary" onclick="saveOp()">บันทึก</button>
    </div>
  </div>
</div>

<script>
// ── CONFIG ─────────────────────────────────────────────
const DOCTORS = ["พ.ระพีพรรณ","พ.เกียรติพร","พ.อารีรัตน์"];
const DOC_COLORS = [
  {border:"#c084fc",bg:"rgba(192,132,252,.15)",text:"#c084fc"},
  {border:"#fb923c",bg:"rgba(251,146,60,.15)", text:"#fb923c"},
  {border:"#34d399",bg:"rgba(52,211,153,.15)", text:"#34d399"},
];
const OPS = [
  "Cesarean section","Hysterectomy","Myomectomy","Ovarian cystectomy",
  "Salpingectomy","Diagnostic laparoscopy","D&C","Colporrhaphy",
  "Pelvic floor repair","Cervical conization","Tubal ligation","Endometrial biopsy",
];
const DAY_CFG = {
  0:{label:"จันทร์",   start:13*60,    end:16*60},
  1:{label:"อังคาร",   start:13*60,    end:16*60},
  2:{label:"พุธ",      start:8*60+30,  end:16*60},
  3:{label:"พฤหัสบดี", start:8*60+30,  end:12*60},
  4:{label:"ศุกร์",    start:13*60,    end:16*60},
};
const PX = 2.6;
const STORAGE_KEY = "ob-sched-v1";

// ── STATE ──────────────────────────────────────────────
let opsData = {};   // { "w_d": [{id,doctor,op,startMin,endMin}] }
let curDay  = 0;
let editId  = null;
let selDoc  = DOCTORS[0];
let resizeState = null;

const dayKey = (w,d) => `${w}_${d}`;
const getW   = ()    => +document.getElementById('weekSel').value;
const getOps = (w,d) => opsData[dayKey(w,d)] || [];
const curOps = ()    => getOps(getW(), curDay);
const cfg    = ()    => DAY_CFG[curDay];

const minToTime = m => `${String(Math.floor(m/60)).padStart(2,'0')}:${String(m%60).padStart(2,'0')}`;
const fmtDur    = m => { const h=Math.floor(m/60),mn=m%60; return h>0?(mn>0?`${h}ชม.${mn}น.`:`${h}ชม.`):`${mn}น.`; };
const genId     = () => Math.random().toString(36).slice(2,10);
const minToPx   = (m,s) => (m-s)*PX;

function overlaps(a,b){ return !(a.endMin<=b.startMin||a.startMin>=b.endMin); }
function hasConflict(op,all){ return all.some(o=>o.id!==op.id&&o.doctor===op.doctor&&overlaps(op,o)); }

// ── STORAGE ────────────────────────────────────────────
function showSync(msg,color){
  const el=document.getElementById('syncMsg');
  el.textContent=msg; el.style.color=color;
  if(msg) setTimeout(()=>{ if(el.textContent===msg) el.textContent=''; },2500);
}

function saveStorage(){
  try{ localStorage.setItem(STORAGE_KEY, JSON.stringify(opsData)); }catch(e){}
  showSync('✓ บันทึกแล้ว','#34d399');
}
function loadStorage(){
  try{
    const raw=localStorage.getItem(STORAGE_KEY);
    if(raw) opsData=JSON.parse(raw);
  }catch(e){ opsData={}; }
}

// ── INIT ───────────────────────────────────────────────
window.onload = function(){
  loadStorage();
  buildDocPills();
  buildDayBtns();
  buildOpSelect();
  buildDocBtns();
  renderAll();
};

function buildDocPills(){
  document.getElementById('docPills').innerHTML =
    DOCTORS.map((d,i)=>`<span class="doc-pill" style="background:${DOC_COLORS[i].bg};border-color:${DOC_COLORS[i].border};color:${DOC_COLORS[i].text}">${d}</span>`).join('');
}

function buildDayBtns(){
  document.getElementById('dayBtns').innerHTML =
    Object.entries(DAY_CFG).map(([d,c])=>
      `<button class="day-btn${+d===curDay?' active':''}" onclick="setDay(${d})">
        ${c.label}<span>${minToTime(c.start)}–${minToTime(c.end)}</span>
      </button>`
    ).join('');
}

function buildOpSelect(){
  const sel=document.getElementById('fOp');
  sel.innerHTML=OPS.map(o=>`<option value="${o}">${o}</option>`).join('');
}

function buildDocBtns(){
  document.getElementById('docBtns').innerHTML =
    DOCTORS.map((d,i)=>
      `<button class="doc-btn" id="dbtn_${i}" onclick="selectDoc('${d}',${i})"
        style="${d===selDoc?`border-color:${DOC_COLORS[i].border};background:${DOC_COLORS[i].bg};color:${DOC_COLORS[i].text}`:''}">${d}</button>`
    ).join('');
}

function selectDoc(d,i){
  selDoc=d;
  document.querySelectorAll('.doc-btn').forEach((b,idx)=>{
    const c=DOC_COLORS[idx];
    b.style.borderColor=idx===i?c.border:'var(--border)';
    b.style.background=idx===i?c.bg:'var(--surface2)';
    b.style.color=idx===i?c.text:'var(--muted)';
  });
  checkModalConflict();
}

function buildTimeSelects(start,end,defStart,defEnd){
  const opts=[];
  for(let m=start;m<=end;m+=30) opts.push(m);
  const html=opts.map(m=>`<option value="${m}">${minToTime(m)}</option>`).join('');
  const fs=document.getElementById('fStart');
  const fe=document.getElementById('fEnd');
  fs.innerHTML=html; fe.innerHTML=html;
  fs.value=defStart; fe.value=defEnd;
}

function setDay(d){
  curDay=+d;
  buildDayBtns();
  renderAll();
}

// ── RENDER ─────────────────────────────────────────────
function renderAll(){
  renderTimeline();
  renderSummary();
  renderWorkload();
  const any=curOps().some(op=>hasConflict(op,curOps()));
  document.getElementById('conflictBanner').classList.toggle('show',any);
}

function renderTimeline(){
  const c=cfg();
  const trackW=(c.end-c.start)*PX;
  const inner=document.getElementById('timelineInner');
  inner.style.minWidth=(trackW+130)+'px';

  // Time axis
  const axis=document.getElementById('timeAxis');
  axis.style.width=trackW+'px';
  axis.style.marginLeft='120px';
  let axHtml='';
  for(let m=c.start;m<=c.end;m+=30){
    const px=minToPx(m,c.start);
    const major=m%60===0||(m===c.start);
    axHtml+=`<div class="time-tick ${major?'major':'minor'}" style="left:${px}px">${minToTime(m)}</div>`;
  }
  axis.innerHTML=axHtml;

  // Tracks
  const area=document.getElementById('trackArea');
  let html='';
  const ops=curOps();
  DOCTORS.forEach((doc,di)=>{
    const c2=DOC_COLORS[di];
    const docOps=ops.filter(o=>o.doctor===doc);
    const mins=docOps.reduce((a,o)=>a+(o.endMin-o.startMin),0);
    html+=`<div class="room-row">
      <div class="room-label">
        <div class="name" style="color:${c2.text}">${doc}</div>
        ${mins>0?`<div class="hrs">${fmtDur(mins)}</div>`:''}
      </div>
      <div class="track" id="track_${di}" style="width:${trackW}px" onclick="trackClick(event,${di})">`;

    // gridlines
    for(let m=c.start;m<=c.end;m+=30){
      const px=minToPx(m,c.start);
      html+=`<div class="gridline" style="left:${px}px;background:${m%60===0?'#3d2d55':'#2a1e40'}"></div>`;
    }

    // op blocks
    docOps.forEach(op=>{
      const conflict=hasConflict(op,ops);
      const bc=conflict?{border:'#fb923c',bg:'rgba(251,146,60,.2)'}:c2;
      const left=minToPx(op.startMin,c.start);
      const width=Math.max((op.endMin-op.startMin)*PX-3,40);
      html+=`<div class="op-block" data-id="${op.id}"
        style="left:${left}px;width:${width}px;background:${bc.bg};border-left-color:${bc.border}"
        onclick="event.stopPropagation();openEdit('${op.id}')">
        <div class="op-name">${op.op}</div>
        <div class="op-time">${minToTime(op.startMin)}–${minToTime(op.endMin)} · ${fmtDur(op.endMin-op.startMin)}</div>
        <div class="resize-handle"
          onmousedown="event.stopPropagation();startResize(event,'${op.id}')"
          ontouchstart="event.stopPropagation();startResizeTouch(event,'${op.id}')"></div>
      </div>`;
    });
    html+=`</div></div>`;
  });
  area.innerHTML=html;
}

function renderSummary(){
  const ops=[...curOps()].sort((a,b)=>a.startMin-b.startMin);
  const sec=document.getElementById('summarySection');
  if(!ops.length){ sec.innerHTML=''; return; }
  const c=cfg();
  let html=`<div class="summary-title">สรุปตาราง · วัน${c.label} · ${minToTime(c.start)}–${minToTime(c.end)}</div>
  <div class="summary-table">`;
  ops.forEach(op=>{
    const di=DOCTORS.indexOf(op.doctor);
    const col=(DOC_COLORS[di]||DOC_COLORS[0]);
    const conflict=hasConflict(op,curOps());
    html+=`<div class="summary-row" onclick="openEdit('${op.id}')">
      <div class="s-time">${minToTime(op.startMin)}–${minToTime(op.endMin)}</div>
      <div class="s-doc" style="color:${conflict?'#fb923c':col.text}">${op.doctor}</div>
      <div class="s-op">${op.op}</div>
      <div class="s-dur">${fmtDur(op.endMin-op.startMin)}</div>
    </div>`;
  });
  html+='</div>';
  sec.innerHTML=html;
}

function renderWorkload(){
  const ops=curOps();
  const c=cfg();
  const total=c.end-c.start;
  const wl=document.getElementById('workload');
  wl.innerHTML=DOCTORS.map((doc,di)=>{
    const mins=ops.filter(o=>o.doctor===doc).reduce((a,o)=>a+(o.endMin-o.startMin),0);
    const pct=Math.min((mins/total)*100,100);
    const col=DOC_COLORS[di];
    return `<div class="wl-card">
      <div class="wl-name" style="color:${col.text}">${doc}</div>
      <div class="wl-bar-bg"><div class="wl-bar-fill" style="width:${pct}%;background:${col.border}"></div></div>
      <div class="wl-text">${mins>0?`${fmtDur(mins)} / ${fmtDur(total)}`:'ว่าง'}</div>
    </div>`;
  }).join('');
}

// ── TRACK CLICK ────────────────────────────────────────
function trackClick(e,di){
  const track=document.getElementById(`track_${di}`);
  const rect=track.getBoundingClientRect();
  const raw=cfg().start+(e.clientX-rect.left)/PX;
  const snap=Math.round(raw/30)*30;
  const s=Math.max(cfg().start,Math.min(snap,cfg().end-30));
  openAdd(DOCTORS[di],s);
}

// ── MODAL ──────────────────────────────────────────────
function openAdd(doc,startMin){
  editId=null;
  selDoc=doc;
  const c=cfg();
  buildDocBtns();
  buildTimeSelects(c.start,c.end,startMin,Math.min(startMin+60,c.end));
  document.getElementById('modalTitle').innerHTML='➕ เพิ่ม Operation<span class="modal-subtitle">วัน'+c.label+'</span>';
  document.getElementById('btnDelete').style.display='none';
  document.getElementById('modalConflict').classList.remove('show');
  onTimeChange();
  document.getElementById('overlay').classList.remove('hidden');
}

function openEdit(id){
  const op=curOps().find(o=>o.id===id);
  if(!op) return;
  editId=id;
  selDoc=op.doctor;
  const c=cfg();
  buildDocBtns();
  buildTimeSelects(c.start,c.end,op.startMin,op.endMin);
  document.getElementById('fOp').value=op.op;
  document.getElementById('modalTitle').innerHTML='✏️ แก้ไข Operation<span class="modal-subtitle">วัน'+c.label+'</span>';
  document.getElementById('btnDelete').style.display='block';
  checkModalConflict();
  onTimeChange();
  document.getElementById('overlay').classList.remove('hidden');
}

function closeModal(){ document.getElementById('overlay').classList.add('hidden'); editId=null; }

function onTimeChange(){ updateDurHint(); checkModalConflict(); }

function updateDurHint(){
  const s=+document.getElementById('fStart').value;
  const e=+document.getElementById('fEnd').value;
  const hint=document.getElementById('durHint');
  if(e>s){ hint.textContent='⏱ '+fmtDur(e-s); hint.style.color='#c084fc'; }
  else { hint.textContent='⚠ เวลาสิ้นสุดต้องมากกว่าเวลาเริ่ม'; hint.style.color='#fb923c'; }
}

function checkModalConflict(){
  const s=+document.getElementById('fStart').value;
  const e=+document.getElementById('fEnd').value;
  const el=document.getElementById('modalConflict');
  if(e<=s){ el.classList.remove('show'); return; }
  const w=getW(),d=curDay;
  const ops=getOps(w,d);
  const conflict=ops.some(o=>o.id!==editId&&o.doctor===selDoc&&overlaps({startMin:s,endMin:e},o));
  if(conflict){ el.textContent='⚠️ '+selDoc+' มี operation ซ้อนทับในช่วงนี้'; el.classList.add('show'); }
  else el.classList.remove('show');
}

function saveOp(){
  const s=+document.getElementById('fStart').value;
  const e=+document.getElementById('fEnd').value;
  if(e<=s){ alert('เวลาสิ้นสุดต้องมากกว่าเวลาเริ่ม'); return; }
  const w=getW(),d=curDay;
  let ops=getOps(w,d);
  if(editId){
    ops=ops.map(o=>o.id===editId?{...o,doctor:selDoc,op:document.getElementById('fOp').value,startMin:s,endMin:e}:o);
  } else {
    ops=[...ops,{id:genId(),doctor:selDoc,op:document.getElementById('fOp').value,startMin:s,endMin:e}];
  }
  opsData[dayKey(w,d)]=ops;
  saveStorage(); closeModal(); renderAll();
}

function deleteOp(){
  const w=getW(),d=curDay;
  opsData[dayKey(w,d)]=(getOps(w,d)).filter(o=>o.id!==editId);
  saveStorage(); closeModal(); renderAll();
}

function clearDay(){
  opsData[dayKey(getW(),curDay)]=[];
  saveStorage(); renderAll();
}

function exportDay(){
  const ops=[...curOps()].sort((a,b)=>a.startMin-b.startMin);
  const c=cfg();
  let txt=`=== OB-GYN OR Schedule สัปดาห์ที่ ${getW()+1} วัน${c.label} ===\n\n`;
  if(!ops.length){ txt+='(ไม่มี operation)\n'; }
  else ops.forEach(o=>txt+=`${minToTime(o.startMin)}–${minToTime(o.endMin)}  ${o.doctor}  ${o.op}  (${fmtDur(o.endMin-o.startMin)})\n`);
  navigator.clipboard.writeText(txt)
    .then(()=>showSync('✓ คัดลอกแล้ว','#34d399'))
    .catch(()=>{ const ta=document.createElement('textarea'); ta.value=txt; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); showSync('✓ คัดลอกแล้ว','#34d399'); });
}

// ── RESIZE ─────────────────────────────────────────────
function startResize(e,id){
  e.preventDefault();
  const op=curOps().find(o=>o.id===id);
  resizeState={id,startX:e.clientX,origEnd:op.endMin,w:getW(),d:curDay};
  document.addEventListener('mousemove',onResizeMove);
  document.addEventListener('mouseup',onResizeUp);
}
function startResizeTouch(e,id){
  const t=e.touches[0];
  const op=curOps().find(o=>o.id===id);
  resizeState={id,startX:t.clientX,origEnd:op.endMin,w:getW(),d:curDay};
  document.addEventListener('touchmove',onResizeMoveTouch,{passive:false});
  document.addEventListener('touchend',onResizeUp);
}
function onResizeMove(e){ applyResize(e.clientX); }
function onResizeMoveTouch(e){ e.preventDefault(); applyResize(e.touches[0].clientX); }
function applyResize(clientX){
  if(!resizeState) return;
  const {id,startX,origEnd,w,d}=resizeState;
  const op=(getOps(w,d)).find(o=>o.id===id);
  const raw=origEnd+(clientX-startX)/PX;
  const snap=Math.round(raw/30)*30;
  const newEnd=Math.max(op.startMin+30,Math.min(snap,cfg().end));
  const arr=(getOps(w,d)).map(o=>o.id===id?{...o,endMin:newEnd}:o);
  opsData[dayKey(w,d)]=arr;
  renderAll();
}
function onResizeUp(){
  saveStorage();
  resizeState=null;
  document.removeEventListener('mousemove',onResizeMove);
  document.removeEventListener('mouseup',onResizeUp);
  document.removeEventListener('touchmove',onResizeMoveTouch);
  document.removeEventListener('touchend',onResizeUp);
}

// Close modal on overlay click
document.getElementById('overlay').addEventListener('click',function(e){ if(e.target===this) closeModal(); });
</script>
